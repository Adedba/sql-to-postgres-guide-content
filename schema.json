{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yourorg/sql-postgres-content/schema.json",
  "title": "SQL to PostgreSQL Topic Content Schema",
  "description": "JSON Schema for validating topic content contributions",
  "type": "object",
  "required": ["id", "title", "description", "concepts"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z_]+$",
      "description": "Unique identifier using lowercase and underscores only"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable topic title"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Brief description of the topic"
    },
    "author": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9]|-(?=[a-zA-Z0-9])){0,38}$",
      "description": "GitHub username of the contributor (optional)"
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "description": "Array of concept comparisons",
      "items": {
        "type": "object",
        "required": ["id", "title", "sqlServer", "postgres"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z_]+$",
            "description": "Unique concept identifier"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Concept title"
          },
          "sqlServer": {
            "type": "object",
            "required": ["code", "description"],
            "properties": {
              "code": {
                "type": "string",
                "minLength": 1,
                "description": "SQL Server code example"
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "Explanation of SQL Server approach"
              },
              "notes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Additional notes or tips"
              }
            }
          },
          "postgres": {
            "type": "object",
            "required": ["code", "description"],
            "properties": {
              "code": {
                "type": "string",
                "minLength": 1,
                "description": "PostgreSQL code example"
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "Explanation of PostgreSQL approach"
              },
              "keyDifferences": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Key differences from SQL Server"
              },
              "notes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Additional notes or tips"
              }
            }
          },
          "keyDifference": {
            "type": "string",
            "description": "Summary of the main difference between SQL Server and PostgreSQL"
          }
        }
      }
    }
  }
}
